{
  "mcpServers": {
    "hayai": {
      "type": "http",
      "url": "http://localhost:7778/mcp"
    },
    "serena": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--project", ".",
        "--enable-web-dashboard", "false",
        "--open-web-dashboard", "false"
      ]
    }
  }
}
